# Supabase público: necessário no browser e no build do Next.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# O painel novo do Supabase pode mostrar este nome. O projeto aceita ANON_KEY ou PUBLISHABLE_KEY.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Use somente em scripts/rotas de servidor quando necessário. Nunca exponha no front-end.
SUPABASE_SERVICE_ROLE_KEY=

# Consultor IA opcional.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
LLM_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
