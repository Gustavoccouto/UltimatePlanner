# Copie este arquivo para .env.local e preencha com os dados do seu projeto Supabase.
# Depois de alterar variáveis NEXT_PUBLIC_*, pare e rode npm run dev novamente.

NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=SUA_ANON_PUBLIC_KEY

# Somente server-side. Nunca use NEXT_PUBLIC_ nesta chave.
SUPABASE_SERVICE_ROLE_KEY=SUA_SERVICE_ROLE_KEY

# IA/Groq
GROQ_API_KEY=SUA_CHAVE_GROQ
GROQ_MODEL=llama-3.3-70b-versatile
